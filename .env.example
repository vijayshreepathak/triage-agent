# ============================================================
# LLM — Anthropic Claude (default)
# ============================================================
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=paste-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=60

# ============================================================
# Search — duckduckgo | tavily | mcp | none
# ============================================================
SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=
SEARCH_MAX_RESULTS=4
SEARCH_MIN_RELEVANCE=0.5

# MCP search (run: python -m mcp_server.server)
# SEARCH_PROVIDER=mcp
MCP_SERVER_URL=http://127.0.0.1:8765/mcp
MCP_SEARCH_TOOL_NAME=search

# ============================================================
# PostgreSQL — Neon (production) or local Docker
# ============================================================
# Neon: postgresql+asyncpg://USER:PASS@HOST/neondb?ssl=require
# Docker: postgresql+asyncpg://triage:triage_secret@localhost:5432/triage
DATABASE_URL=sqlite+aiosqlite:///./triage.db

# ============================================================
# Auth — none | api_key | clerk
# ============================================================
AUTH_MODE=clerk
API_KEYS=

# Clerk — https://dashboard.clerk.com (or: npx clerk env pull --file .env)
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# ============================================================
# Production hardening
# ============================================================
RATE_LIMIT_PER_MINUTE=30
MAX_RETRIES=3
RETRY_BASE_DELAY_SECONDS=0.5
APP_ENV=dev
LOG_LEVEL=INFO
DEBUG_ENDPOINT_ENABLED=true
