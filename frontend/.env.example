# Local dev — Next.js rewrites /engine/* to the FastAPI backend
API_BACKEND_URL=http://127.0.0.1:8000

# Production (Vercel) — call Render directly (avoids Vercel proxy 502 timeouts on triage)
NEXT_PUBLIC_API_URL=https://triage-agent-7xts.onrender.com

# Clerk — required (app will not open without sign-in)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
