# Local dev — Next.js rewrites /api/* to the FastAPI backend
API_BACKEND_URL=http://127.0.0.1:8000

# Legacy / optional (client uses same-origin /api proxy)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Clerk (optional — omit to run without auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Production (Vercel) — set in Vercel dashboard, not in this file:
# API_BACKEND_URL=https://your-api.onrender.com
