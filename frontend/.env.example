# Local dev — Next.js rewrites /engine/* to the FastAPI backend
API_BACKEND_URL=http://127.0.0.1:8000

# Production (Vercel) — your Render/Railway URL, NO /api suffix:
# API_BACKEND_URL=https://triage-agent-7xts.onrender.com

# Clerk (optional — omit to run without auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
